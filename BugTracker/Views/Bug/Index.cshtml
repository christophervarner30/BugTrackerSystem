@model IEnumerable<BugTracker.Models.Bug>

@{
    ViewData["Title"] = "Bug List";
}

<h1>Bug Tracker System</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Bug</a>
</p>
<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>ID</th>
            <th>Title</th>
            <th>Priority</th>
            <th>Created Date</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Title</td>
                <td>
                    @{
                        string priorityClass = item.Priority switch
                        {
                            BugTracker.Models.PriorityLevel.Low => "text-success",
                            BugTracker.Models.PriorityLevel.Medium => "text-warning",
                            BugTracker.Models.PriorityLevel.High => "text-danger",
                            _ => ""
                        };
                    }
                    <span class="@priorityClass">@item.Priority</span>
                </td>
                <td>@item.CreatedDate.ToString("MM/dd/yyyy")</td>
                <td>
                    @if (item.IsResolved)
                    {
                        <span class="badge bg-success">Resolved</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Open</span>
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                </td>
            </tr>
        }
    </tbody>
</table>
